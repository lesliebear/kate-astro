---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Video from "../../components/Video/Video";
import videoList from "../../data/video-list.json";

export interface Props {
  vidIDs: string[];
  role: string;
  rentalUrl: string | undefined;
  press: { pub: string; link: string }[] | undefined;
}

export async function getStaticPaths() {
  const videos = [...videoList.filmAndTv, ...videoList.musicVideos];
  return videos.map((video: any) => {
    const {
      vidIDs,
      title,
      role = "Director",
      rentalUrl = undefined,
      press = undefined,
    } = video;
    return {
      params: { slug: title },
      props: { vidIDs, role, rentalUrl, press },
    };
  });
}

const { slug } = Astro.params;
const { vidIDs, role, rentalUrl, press }: Props = Astro.props;
---

<BaseLayout>
  <Video
    vidIDs={vidIDs}
    title={slug}
    role={role}
    rentalUrl={rentalUrl}
    press={press}
    client:load
  />
</BaseLayout>
